# build output
dist/
.output/
.wrangler/

# dependencies
node_modules/

# EXCEPTION: the folded-in Expo web build (public/app) bundles its icon fonts
# and other assets under a node_modules/ path. Without re-including them here,
# the `node_modules/` rule above drops them from git, so Cloudflare never gets
# the Ionicons font -> it 404s on the live site and every icon is a square.
!public/app/**/node_modules/
!public/app/**/node_modules/**

# generated types
.astro/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# environment / editor / OS
.env
.env.production
.DS_Store
.vscode/*
!.vscode/extensions.json

.dev.vars*
!.dev.vars.example
!.env.example
