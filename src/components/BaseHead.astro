---
// All the <head> SEO tags live here so every page gets them right.
import { SITE_TITLE, SITE_OG_IMAGE, SOCIAL_LINKS, CONTACT_EMAIL } from '../consts';
import '../styles/global.css';

interface Props {
  title: string;        // unique per page
  description: string;  // unique per page (shows under the title on Google)
  image?: string;       // social-share preview image
  /** 'website' for normal pages, 'article' for blog posts */
  type?: 'website' | 'article';
}

const { title, description, image = SITE_OG_IMAGE, type = 'website' } = Astro.props;

// Astro.site comes from `site:` in astro.config.mjs. Astro.url is the current page.
// new URL(path, base) turns relative paths into absolute ones, and social sites
// require absolute image/URL paths to render a preview.
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// Organization schema, sitewide: tells Google (and AI crawlers) who is behind
// the site, with sameAs pointing at our real profiles. This is the E-E-A-T
// "who runs this" signal small brands usually miss.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_TITLE,
  url: new URL('/', Astro.site).toString(),
  logo: new URL('/questling-icon.png', Astro.site).toString(),
  email: CONTACT_EMAIL,
  sameAs: SOCIAL_LINKS.map((s) => s.url),
};

// Speculation Rules: Chrome/Edge prerender the app when a visitor hovers any
// link into /app, so the marketing-to-app jump feels instant in real use.
const speculation = {
  prerender: [{ where: { href_matches: '/app/*' }, eagerness: 'moderate' }],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Primary SEO -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />

<!-- Favicon (the gem) -->
<link rel="icon" type="image/png" href="/questling-icon.png" />
<link rel="apple-touch-icon" href="/questling-icon.png" />
<meta name="theme-color" content="#4f46c7" />

<!-- Open Graph (Facebook, iMessage, Slack, LinkedIn previews) -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Who runs this site (E-E-A-T) + instant app prerender on link hover -->
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="speculationrules" set:html={JSON.stringify(speculation)} />

<!-- Fonts: Inter, with preconnect so it loads fast -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- Load the font stylesheet without blocking render: fetch as low-priority
     "print", then flip to "all" once it arrives. The metric-matched Inter
     fallback keeps layout shift tiny during the swap. -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
  />
</noscript>
