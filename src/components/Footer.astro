---
import { SITE_TITLE, SITE_TAGLINE, NAV_LINKS, CONTACT_EMAIL, PRIVACY_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__brand">
      <a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
        <img src="/questling-icon.png" alt="" width="34" height="34" class="brand__mark" />
        <span class="brand__name">{SITE_TITLE}</span>
      </a>
      <p class="site-footer__tag">{SITE_TAGLINE}</p>
    </div>

    <nav class="site-footer__nav" aria-label="Footer">
      <h2 class="site-footer__h">Explore</h2>
      <ul>
        {NAV_LINKS.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__nav">
      <h2 class="site-footer__h">Company</h2>
      <ul>
        <li><a href={PRIVACY_URL} target="_blank" rel="noopener">Privacy Policy</a></li>
        <li><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></li>
      </ul>
    </div>
  </div>

  <div class="container site-footer__bar">
    <p>© {year} {SITE_TITLE}. All rights reserved.</p>
    <p>Made for parents who want more for their kids than a screen.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--line);
    margin-top: 2rem;
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 2rem;
    padding-block: clamp(2.5rem, 5vw, 3.5rem);
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; }
  .brand:hover { text-decoration: none; }
  .brand__mark { border-radius: 9px; }
  .brand__name { font-weight: 800; font-size: 1.2rem; color: var(--ink); }
  .site-footer__tag { color: var(--ink-soft); margin-top: 0.6rem; }
  .site-footer__h {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink);
    margin: 0 0 0.8rem;
  }
  .site-footer__nav ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.55rem; }
  .site-footer__nav a { color: var(--ink-soft); font-size: 0.95rem; }
  .site-footer__nav a:hover { color: var(--primary); }
  .site-footer__bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    border-top: 1px solid var(--line);
    padding-block: 1.2rem;
  }
  .site-footer__bar p { margin: 0; font-size: 0.85rem; color: var(--ink-soft); }

  @media (max-width: 700px) {
    .site-footer__grid { grid-template-columns: 1fr 1fr; }
    .site-footer__brand { grid-column: 1 / -1; }
  }
</style>
