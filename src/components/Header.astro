---
import { SITE_TITLE, NAV_LINKS } from '../consts';
---

<header class="site-header">
  <div class="container site-header__inner">
    <!-- Logo: the green gem + wordmark, links home -->
    <a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
      <img src="/questling-icon.png" alt="" width="36" height="36" class="brand__mark" />
      <span class="brand__name">{SITE_TITLE}</span>
    </a>

    <!-- Hamburger (shown only on mobile via CSS) -->
    <button
      class="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="primary-nav"
    >
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="primary-nav" class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li><a class="btn btn--gem site-nav__cta" href="/quests">Try it free</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 246, 253, 0.85);
    backdrop-filter: saturate(180%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 68px;
  }
  .brand { display: inline-flex; align-items: center; gap: 0.6rem; }
  .brand:hover { text-decoration: none; }
  .brand__mark { border-radius: 9px; box-shadow: var(--shadow-sm); }
  .brand__name { font-weight: 800; font-size: 1.25rem; color: var(--ink); letter-spacing: -0.01em; }

  .site-nav__list {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav a {
    color: var(--ink);
    font-weight: 500;
    font-size: 0.98rem;
    white-space: nowrap; /* never let a label wrap to two lines */
  }
  .site-nav a:hover { color: var(--primary); text-decoration: none; }
  .site-nav__cta, .site-nav__cta:hover { color: #fff; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    cursor: pointer;
  }
  .nav-toggle__bar {
    display: block;
    width: 20px;
    height: 2px;
    margin-inline: auto;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded='true'] .nav-toggle__bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- Mobile / narrow ---- */
  /* Switch to the hamburger before the 7-item nav gets squished and wraps
     (which used to happen in a laptop split-screen around 820-900px). */
  @media (max-width: 960px) {
    .nav-toggle { display: flex; }
    .site-nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--surface);
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-md);
      /* Collapse to true content height (no magic max-height) via the grid-rows
         trick: the row animates 0fr to 1fr and the list clips itself. */
      display: grid;
      grid-template-rows: 0fr;
      /* Hidden from keyboard/AT while collapsed, so links aren't tabbable off-screen.
         visibility flips to visible instantly on open and lags out on close. */
      visibility: hidden;
      transition: grid-template-rows 0.25s ease, visibility 0.25s ease;
    }
    .site-nav.is-open { grid-template-rows: 1fr; visibility: visible; }
    .site-nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0.5rem 1rem 1.25rem;
      overflow: hidden;
      min-height: 0;
    }
    .site-nav__list li { padding: 0.3rem 0; }
    .site-nav__list a { display: block; padding: 0.6rem 0.4rem; }
    .site-nav__cta { text-align: center; margin-top: 0.5rem; }
  }
</style>

<script>
  // Toggle the mobile menu open/closed. Pure browser-side UI, no server.
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('primary-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
  // Close the menu after tapping a link (so the next page isn't covered).
  nav?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
    })
  );
  // Escape closes the menu and hands focus back to the toggle.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nav?.classList.contains('is-open')) {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
      (toggle as HTMLElement | null)?.focus();
    }
  });
</script>
