---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';

const title = 'Follow Questling on Instagram, TikTok & YouTube';
const description =
  'Follow Questling for screen-free activity ideas, quests to do with your kids, and updates as we build toward launch.';

// Simple inline glyphs so the page has no external icon dependency.
const icons: Record<string, string> = {
  instagram:
    '<svg viewBox="0 0 24 24" width="30" height="30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>',
  tiktok:
    '<svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M16.2 3c.35 2.06 1.62 3.63 3.8 3.9v2.66c-1.27.02-2.53-.38-3.6-1.1v5.83a5.42 5.42 0 1 1-5.42-5.42c.3 0 .6.03.9.08v2.73a2.7 2.7 0 1 0 1.87 2.57V3h2.45z"/></svg>',
  youtube:
    '<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M23 12s0-3.2-.41-4.73a2.5 2.5 0 0 0-1.76-1.76C19.3 5.1 12 5.1 12 5.1s-7.3 0-8.83.41A2.5 2.5 0 0 0 1.4 7.27C1 8.8 1 12 1 12s0 3.2.41 4.73a2.5 2.5 0 0 0 1.76 1.76C4.7 18.9 12 18.9 12 18.9s7.3 0 8.83-.41a2.5 2.5 0 0 0 1.76-1.76C23 15.2 23 12 23 12zM9.75 15.35v-6.7L15.5 12l-5.75 3.35z"/></svg>',
};
---

<BaseLayout title={title} description={description}>
  <section class="section">
    <div class="container center">
      <span class="section__eyebrow">Socials</span>
      <h1>Come follow along.</h1>
      <p class="section__lead">
        Screen-free ideas, quests to try with your kids, and a peek behind the scenes
        as we build Questling. Follow us wherever you already scroll.
      </p>

      <div class="socials-grid">
        {SOCIAL_LINKS.map((s) => (
          <a class="card social-card" href={s.url} target="_blank" rel="noopener" aria-label={`Questling on ${s.name}`}>
            <span class="social-card__icon" set:html={icons[s.icon]} />
            <span class="social-card__name">{s.name}</span>
            <span class="social-card__handle">{s.handle}</span>
          </a>
        ))}
      </div>

      <p class="socials-note">
        Not on social? <a href="/#get-notified">Get notified at launch instead →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  h1 { margin-top: 0.6rem; }
  .socials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
    max-width: 680px;
    margin: 2.6rem auto 0;
  }
  .social-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    padding: 2rem 1rem 1.6rem;
  }
  .social-card:hover { text-decoration: none; }
  .social-card__icon {
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--primary-tint);
    color: var(--primary);
    margin-bottom: 0.5rem;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .social-card:hover .social-card__icon { background: var(--primary); color: #fff; }
  .social-card__name { font-weight: 700; color: var(--ink); font-size: 1.1rem; }
  .social-card__handle { color: var(--ink-soft); font-size: 0.92rem; }
  .socials-note { margin-top: 2.4rem; color: var(--ink-soft); }

  @media (max-width: 560px) {
    .socials-grid { grid-template-columns: 1fr; max-width: 320px; }
  }
</style>
